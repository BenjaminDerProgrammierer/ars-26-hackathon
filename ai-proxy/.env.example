# Never commit the real provider key.
OPENROUTER_API_KEY=

# Generate both with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
API_KEY_PEPPER=replace-with-an-independent-random-secret

APP_BASE_URL=http://localhost:8787
PORT=8787
DATABASE_PATH=./data/proxy.sqlite
ADMIN_EMAILS=organizer@example.com

# The only model exposed to contestants.
OPENROUTER_MODEL=mistralai/mistral-medium-3-5
CONTESTANT_BUDGET_USD=20
MAX_OUTPUT_TOKENS=4096

# Current OpenRouter list price for Mistral Medium 3.5. Update if pricing changes.
MODEL_INPUT_USD_PER_MILLION=1.5
MODEL_OUTPUT_USD_PER_MILLION=7.5

# Optional OpenRouter attribution headers.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Ars Electronica Festival 2026 Hackathon

# Overall deadline for connecting to OpenRouter and consuming its response.
OPENROUTER_TIMEOUT_MS=300000
