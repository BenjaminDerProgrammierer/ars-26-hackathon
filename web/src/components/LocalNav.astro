---
import { href, type Lang, useTranslations } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
  { label: t("nav.home"), url: href(lang), exact: true },
  { label: t("nav.about"), url: href(lang, "hackathon") },
  { label: t("nav.tutorials"), url: href(lang, "tutorials") },
  { label: t("nav.datasets"), url: href(lang, "datasets") },
  { label: t("nav.agents"), url: href(lang, "coding-agents") },
];

const loginUrl = href(lang, "login");
const path = Astro.url.pathname;

function isCurrent(url: string, exact = false): boolean {
  return exact ? path === url : path.startsWith(url);
}
---

<nav class="local-nav" aria-label={t("nav.local.label")}>
  <div class="wrap bar">
    <ul>
      {
        items.map((item) => (
          <li>
            <a
              href={item.url}
              aria-current={isCurrent(item.url, item.exact) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      class="button button--action login"
      href={loginUrl}
      aria-current={isCurrent(loginUrl) ? "page" : undefined}
    >
      {t("nav.login")}
    </a>
  </div>
</nav>

<style>
  .local-nav {
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-rule);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-block: var(--space-2);
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  a:not(.login) {
    display: inline-block;
    padding-block: var(--space-2);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 3px solid transparent;
  }

  a:not(.login):hover {
    border-bottom-color: var(--color-rule);
  }

  a:not(.login)[aria-current="page"] {
    font-weight: 700;
    border-bottom-color: var(--color-identity);
  }

  .login {
    padding: var(--space-2) var(--space-4);
  }

  .login[aria-current="page"] {
    outline: 2px solid var(--color-ink);
    outline-offset: -2px;
  }
</style>
