---
import { href, type Lang, useTranslations } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="site-footer">
  <div class="wrap bar">
    <p class="claim">
      <strong>{t("site.title")}</strong> // {t("footer.claim")}
    </p>
    <ul>
      <li><a href={href(lang, "hackathon")}>{t("footer.contact")}</a></li>
      <li><a href={href(lang, "hackathon")}>{t("footer.imprint")}</a></li>
      <li><a href={href(lang, "hackathon")}>{t("footer.privacy")}</a></li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink);
    color: var(--color-paper);
    margin-top: var(--space-8);
  }

  .site-footer :global(:focus-visible) {
    outline-color: var(--color-paper);
  }

  .bar {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-6);
    font-size: var(--text-sm);
  }

  .claim {
    margin: 0;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
