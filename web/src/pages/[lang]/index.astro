---
import ColorBand from "../../components/ColorBand.astro";
import Hero from "../../components/Hero.astro";
import Milestones from "../../components/Milestones.astro";
import SplitSection from "../../components/SplitSection.astro";
import { href, type Lang, useTranslations } from "../../i18n/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "de" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const copy = {
  en: {
    title: "AI Hackathon",
    heroKicker:
      "A sub-event of Ars Electronica Festival 2026 // Future Begins / Negotiating Humanity",
    intro:
      "Build apps, maps, and installations that combine the festival program export with open data from the City of Linz — with optional hosted development and AI access. Two days, one festival, two data worlds.",
    primaryAction: "Create your account",
    secondaryAction: "How the hackathon works",
    statement: "Two data worlds. One city. Two days.",
    datasets: {
      heading: "The festival, as data",
      body: "Around 546 projects, 240 artists and organizations, 111 venues, and 178 scheduled slots — the entire Negotiating Humanity program as one JSON file, ready to combine with transit stops, trees, air quality, and historical maps of Linz.",
      link: "Explore the datasets",
    },
    tutorials: {
      heading: "Learn the ropes first",
      body: "Four short tutorials take you from raw export to a working prototype: understand the festival dataset, join it with city data, build with coding agents, and configure pi.dev with the provided or your own models.",
      link: "Read the tutorials",
    },
    agents: {
      heading: "Development & AI, your choice",
      body: "Choose at signup: use your own setup, add OpenRouter access to Mistral Medium 3.5 with a $20 budget per attendee, or work in a complete browser-based development environment hosted in Austria with pi.dev preinstalled. The hosted environment requires the AI add-on.",
      link: "Explore the development options",
    },
    milestonesHeading: "What happens when",
    milestones: [
      {
        date: "July 2026",
        title: "Registration opens",
        detail: "The exact registration date will be announced here.",
      },
      {
        date: "September 11, 2026",
        title: "Kick-off & team matching",
        detail: "Meet the data, the agents, and your future teammates.",
      },
      {
        date: "September 11–12, 2026",
        title: "Hacking",
        detail:
          "Build, test, and demo-proof your prototype with mentor support.",
      },
      {
        date: "September 12, 2026, evening",
        title: "Jury & awards",
        detail:
          "Present your project to festival curators and city representatives.",
      },
    ],
  },
  de: {
    title: "AI Hackathon",
    heroKicker:
      "Ein Sub-Event des Ars Electronica Festival 2026 // Future Begins / Negotiating Humanity",
    intro:
      "Baut Apps, Karten und Installationen, die den Programm-Export des Festivals mit offenen Daten der Stadt Linz verbinden — mit optionaler gehosteter Entwicklungsumgebung und KI-Zugang. Zwei Tage, ein Festival, zwei Datenwelten.",
    primaryAction: "Konto erstellen",
    secondaryAction: "So funktioniert der Hackathon",
    statement: "Zwei Datenwelten. Eine Stadt. Zwei Tage.",
    datasets: {
      heading: "Das Festival als Daten",
      body: "Rund 546 Projekte, 240 Künstler:innen und Organisationen, 111 Orte und 178 Zeitslots — das gesamte Programm von Negotiating Humanity als eine JSON-Datei, bereit zur Kombination mit Haltestellen, Bäumen, Luftgüte und historischen Karten von Linz.",
      link: "Zu den Datensätzen",
    },
    tutorials: {
      heading: "Zuerst die Grundlagen",
      body: "Vier kurze Tutorials führen vom rohen Export zum funktionierenden Prototyp: den Festival-Datensatz verstehen, mit Stadtdaten verbinden, mit Coding Agents bauen und pi.dev mit bereitgestellten oder eigenen Modellen konfigurieren.",
      link: "Zu den Tutorials",
    },
    agents: {
      heading: "Entwicklung & KI nach Wahl",
      body: "Wählt bei der Anmeldung: euer eigenes Setup, OpenRouter-Zugang zu Mistral Medium 3.5 mit 20 US-Dollar Budget pro Person oder eine vollständige browserbasierte Entwicklungsumgebung in Österreich mit vorinstalliertem pi.dev. Für die gehostete Umgebung ist das KI-Add-on erforderlich.",
      link: "Zu den Entwicklungsoptionen",
    },
    milestonesHeading: "Was passiert wann",
    milestones: [
      {
        date: "Juli 2026",
        title: "Anmeldung öffnet",
        detail: "Das genaue Anmeldedatum wird hier bekannt gegeben.",
      },
      {
        date: "11. September 2026",
        title: "Kick-off & Team-Matching",
        detail: "Lernt die Daten, die Agents und eure künftigen Teams kennen.",
      },
      {
        date: "11.–12. September 2026",
        title: "Hacken",
        detail:
          "Bauen, testen und den Prototyp demo-fest machen — mit Mentoring.",
      },
      {
        date: "12. September 2026, abends",
        title: "Jury & Preise",
        detail:
          "Präsentiert euer Projekt vor Kurator:innen und Stadtvertreter:innen.",
      },
    ],
  },
}[lang];
---

<BaseLayout lang={lang} title={copy.title} description={copy.intro}>
  <Hero title={copy.title} kicker={copy.heroKicker} datePlace={t("site.datePlace")} />

  <section class="intro">
    <div class="wrap wrap--reading">
      <p>{copy.intro}</p>
      <p class="actions">
        <a class="button button--action" href={href(lang, "login")}>{copy.primaryAction}</a>
        <a class="secondary" href={href(lang, "hackathon")}>{copy.secondaryAction}</a>
      </p>
    </div>
  </section>

  <SplitSection>
    <div slot="media" class="media-field">
      <span class="section-mark section-mark--identity" aria-hidden="true">01</span>
    </div>
    <h2>{copy.datasets.heading}</h2>
    <p>{copy.datasets.body}</p>
    <p><a href={href(lang, "datasets")}>{copy.datasets.link}</a></p>
  </SplitSection>

  <ColorBand color="var(--color-program)">
    <p>{copy.statement}</p>
  </ColorBand>

  <SplitSection flip>
    <div slot="media" class="media-field">
      <span class="section-mark section-mark--program" aria-hidden="true">02</span>
    </div>
    <h2>{copy.tutorials.heading}</h2>
    <p>{copy.tutorials.body}</p>
    <p><a href={href(lang, "tutorials")}>{copy.tutorials.link}</a></p>
  </SplitSection>

  <SplitSection>
    <div slot="media" class="media-field">
      <span class="section-mark section-mark--context" aria-hidden="true">03</span>
    </div>
    <h2>{copy.agents.heading}</h2>
    <p>{copy.agents.body}</p>
    <p><a href={href(lang, "coding-agents")}>{copy.agents.link}</a></p>
  </SplitSection>

  <Milestones heading={copy.milestonesHeading} items={copy.milestones} />
</BaseLayout>

<style>
  .intro {
    padding-block: var(--space-7) 0;
  }

  .intro p:first-child {
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
    margin-top: var(--space-5);
  }

  .media-field {
    background: var(--color-wash);
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 3 / 2;
  }

  .section-mark {
    font-size: clamp(5rem, 16vw, 10rem);
    font-weight: 700;
    line-height: 1;
  }

  .section-mark--identity {
    color: var(--color-identity);
  }

  .section-mark--program {
    color: var(--color-program);
  }

  .section-mark--context {
    color: var(--color-context);
  }
</style>
