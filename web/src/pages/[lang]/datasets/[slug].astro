---
import { getCollection, render } from "astro:content";
import { href, type Lang } from "../../../i18n/ui";
import ProseLayout from "../../../layouts/ProseLayout.astro";

const statusOrder = [
  "essential",
  "recommended",
  "optional",
  "in-progress",
] as const;
type DatasetStatus = (typeof statusOrder)[number];

export async function getStaticPaths() {
  const datasets = await getCollection("datasets");
  return ["en", "de"].flatMap((lang) =>
    datasets.map((entry) => ({
      params: { lang, slug: entry.id.split("/")[0] },
      props: { entry },
    })),
  );
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const { Content } = await render(entry);

const datasets = (await getCollection("datasets")).sort((a, b) => {
  const statusDifference =
    statusOrder.indexOf(a.data.status) - statusOrder.indexOf(b.data.status);
  return statusDifference || a.data.title.localeCompare(b.data.title, "de");
});
const index = datasets.findIndex((dataset) => dataset.id === entry.id);
const previous = index > 0 ? datasets[index - 1] : undefined;
const next = index < datasets.length - 1 ? datasets[index + 1] : undefined;

const copy = {
  en: {
    back: "All datasets",
    provider: "Provider",
    status: "Readiness",
    format: "Format",
    license: "License",
    vintage: "Data vintage",
    sourceLanguage: "The authoritative notes below are maintained in German.",
    source: "View source README",
    statusLabel: {
      essential: "Use",
      recommended: "Recommended",
      "in-progress": "Pending",
      optional: "Optional",
    },
  },
  de: {
    back: "Alle Datensätze",
    provider: "Anbieter",
    status: "Reifegrad",
    format: "Format",
    license: "Lizenz",
    vintage: "Datenstand",
    sourceLanguage:
      "Die folgenden verbindlichen Hinweise werden auf Deutsch gepflegt.",
    source: "Quell-README öffnen",
    statusLabel: {
      essential: "Verwenden",
      recommended: "Empfohlen",
      "in-progress": "In Klärung",
      optional: "Optional",
    },
  },
}[lang];

function datasetHref(id: string): string {
  return href(lang, `datasets/${id.split("/")[0]}`);
}

const sourceUrl = `https://github.com/BenjaminDerProgrammierer/ars-26-hackathon/blob/main/opendata-linz/${entry.id.split("/")[0]}/README.md`;
---

<ProseLayout
  lang={lang}
  title={entry.data.title}
  intro={entry.data.summary}
  bandColor="var(--color-places)"
  textColor="var(--color-paper)"
>
  <p class="back"><a href={href(lang, "datasets")}>← {copy.back}</a></p>

  <dl class="metadata">
    <div>
      <dt>{copy.status}</dt>
      <dd><span class={`status status--${entry.data.status}`}>{copy.statusLabel[entry.data.status as DatasetStatus]}</span></dd>
    </div>
    <div>
      <dt>{copy.provider}</dt>
      <dd>{entry.data.provider}</dd>
    </div>
    <div>
      <dt>{copy.format}</dt>
      <dd>{entry.data.format}</dd>
    </div>
    <div>
      <dt>{copy.license}</dt>
      <dd>{entry.data.license}</dd>
    </div>
    <div>
      <dt>{copy.vintage}</dt>
      <dd>{entry.data.data_vintage}</dd>
    </div>
  </dl>

  {lang === "en" && <p class="language-note">{copy.sourceLanguage}</p>}

  <Content />

  <p class="source-link"><a href={sourceUrl}>{copy.source} ↗</a></p>

  <nav class="pager" aria-label={copy.back}>
    {
      previous ? (
        <a href={datasetHref(previous.id)} rel="prev">
          ← {previous.data.title}
        </a>
      ) : (
        <a href={href(lang, "datasets")} rel="up">← {copy.back}</a>
      )
    }
    {next && <a href={datasetHref(next.id)} rel="next">{next.data.title} →</a>}
  </nav>
</ProseLayout>

<style>
  .back {
    margin-bottom: var(--space-5);
    font-weight: 600;
  }

  .metadata {
    margin: 0 0 var(--space-6);
    border-top: 3px solid var(--color-places);
  }

  .metadata > div {
    display: grid;
    gap: var(--space-2) var(--space-4);
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }

  @media (min-width: 34rem) {
    .metadata > div {
      grid-template-columns: 8rem 1fr;
    }
  }

  dt {
    color: var(--color-muted);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  dd {
    margin: 0;
  }

  .status {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    border: 1px solid currentColor;
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.3;
  }

  .status--essential {
    color: #006b55;
  }

  .status--recommended {
    color: #9d1448;
  }

  .status--in-progress {
    color: #8a4b00;
  }

  .status--optional {
    color: #5f356e;
  }

  .language-note {
    padding: var(--space-3) var(--space-4);
    border-left: 3px solid var(--color-context);
    background: var(--color-wash);
    font-size: var(--text-sm);
  }

  .source-link {
    margin-top: var(--space-6);
    font-weight: 600;
  }

  .pager {
    display: flex;
    justify-content: space-between;
    gap: var(--space-5);
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-rule);
    font-weight: 500;
  }

  .pager a:last-child {
    text-align: right;
  }
</style>
