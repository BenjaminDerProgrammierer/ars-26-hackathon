---
import { getCollection, render } from "astro:content";
import { href, type Lang } from "../../../../i18n/ui";
import ProseLayout from "../../../../layouts/ProseLayout.astro";
import { rewriteDatasetLinks } from "../../../../markdown/dataset-links.mjs";

export async function getStaticPaths() {
  const documents = await getCollection("datasetDocs");

  return ["en", "de"].flatMap((lang) =>
    documents.map((entry) => {
      const [slug, filename] = entry.id.split("/");

      return {
        params: { lang, slug, doc: filename.toLowerCase() },
        props: { entry, slug },
      };
    }),
  );
}

const { entry, slug } = Astro.props;
const lang = Astro.params.lang as Lang;
const { Content } = await render(entry);
const datasets = await getCollection("datasets");
const datasetSlugs = new Set(
  datasets.map((dataset) => dataset.id.split("/")[0]),
);
const renderedContent = entry.rendered?.html
  ? rewriteDatasetLinks(
      entry.rendered.html,
      href(lang, "datasets"),
      datasetSlugs,
    )
  : undefined;
const datasetUrl = href(lang, `datasets/${slug}`);
const copy = {
  en: {
    back: "Back to dataset",
    sourceLanguage:
      "The authoritative API reference below is maintained in German.",
  },
  de: {
    back: "Zurück zum Datensatz",
    sourceLanguage: "",
  },
}[lang];
---

<ProseLayout
  lang={lang}
  title={entry.data.title}
  intro={entry.data.summary}
  bandColor="var(--color-places)"
  textColor="var(--color-paper)"
>
  <p><a href={datasetUrl}>← {copy.back}</a></p>

  {lang === "en" && <p class="language-note">{copy.sourceLanguage}</p>}

  {renderedContent ? <Fragment set:html={renderedContent} /> : <Content />}
</ProseLayout>
