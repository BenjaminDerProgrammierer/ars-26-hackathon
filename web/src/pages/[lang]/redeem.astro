---
import { type Lang, useTranslations } from "../../i18n/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "de" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<BaseLayout
  lang={lang}
  title={t("redeem.title")}
  description={t("redeem.intro")}
>
  <section class="title-band">
    <div class="wrap wrap--reading">
      <p class="eyebrow">{t("redeem.eyebrow")}</p>
      <h1>{t("redeem.title")}</h1>
      <p class="intro">{t("redeem.intro")}</p>
    </div>
  </section>

  <section class="redeem-section">
    <div class="wrap wrap--reading">
      <form class="redeem-form" method="get" data-redeem-form>
        <label for="redeem-code">{t("redeem.code.label")}</label>
        <div class="form-row">
          <input
            id="redeem-code"
            name="code"
            type="text"
            autocomplete="off"
            required
            data-redeem-input
          />
          <button class="button button--action" type="submit">
            {t("redeem.submit")}
          </button>
        </div>
      </form>

      <div class="redeem-result" hidden data-redeem-result aria-live="polite">
        <p class="result-label">{t("redeem.result.label")}</p>
        <output data-redeem-output></output>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { lookupRedeemCode } from "../../redeem/data";

  const form = document.querySelector<HTMLFormElement>("[data-redeem-form]");
  const input = document.querySelector<HTMLInputElement>("[data-redeem-input]");
  const result = document.querySelector<HTMLElement>("[data-redeem-result]");
  const output = document.querySelector<HTMLOutputElement>("[data-redeem-output]");
  const code = new URL(window.location.href).searchParams.get("code")?.trim();

  if (form && input && result && output && code) {
    input.value = code;
    output.textContent = lookupRedeemCode(code);
    result.hidden = false;
  }
</script>

<style>
  .title-band {
    background: var(--color-action);
    color: var(--color-ink);
    padding-block: var(--space-7);
  }

  .eyebrow {
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: var(--text-2xl);
    text-transform: uppercase;
  }

  .intro {
    max-width: var(--width-reading);
    margin: var(--space-4) 0 0;
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .redeem-section {
    padding-block: var(--space-7) var(--space-8);
  }

  .redeem-form {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-rule);
  }

  label,
  .result-label {
    display: block;
    margin-bottom: var(--space-2);
    font-weight: 600;
  }

  .form-row {
    display: flex;
    gap: var(--space-3);
  }

  input {
    min-width: 0;
    flex: 1;
    padding: var(--space-3);
    border: 1px solid var(--color-muted);
    background: var(--color-paper);
    color: var(--color-ink);
    font: inherit;
  }

  .redeem-result {
    margin-top: var(--space-6);
    padding: var(--space-5);
    border-left: 4px solid var(--color-action);
    background: var(--color-wash);
  }

  .result-label {
    margin-top: 0;
    color: var(--color-muted);
    font-size: var(--text-sm);
    text-transform: uppercase;
  }

  output {
    display: block;
    overflow-wrap: anywhere;
    font-size: var(--text-xl);
    font-weight: 700;
  }

  @media (max-width: 32rem) {
    .form-row {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
