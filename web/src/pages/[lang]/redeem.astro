---
import { isLang, useTranslations } from "../../i18n/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { lookupRedeemCode } from "../../redeem/data";

export const prerender = false;

const lang = isLang(Astro.params.lang) ? Astro.params.lang : "en";
const t = useTranslations(lang);
const code = Astro.url.searchParams.get("code")?.trim() || "";
let accessText: string | null = null;
let lookupError = false;

if (code) {
  try {
    accessText = await lookupRedeemCode(code);
  } catch (error: unknown) {
    console.error("Redeem code lookup failed", error);
    lookupError = true;
  }
}
---

<BaseLayout
  lang={lang}
  title={t("redeem.title")}
  description={t("redeem.intro")}
>
  <section class="title-band">
    <div class="wrap wrap--reading">
      <p class="eyebrow">{t("redeem.eyebrow")}</p>
      <h1>{t("redeem.title")}</h1>
      <p class="intro">{t("redeem.intro")}</p>
    </div>
  </section>

  <section class="redeem-section">
    <div class="wrap wrap--reading">
      <form class="redeem-form" method="get" data-redeem-form>
        <label for="redeem-code">{t("redeem.code.label")}</label>
        <div class="form-row">
          <input
            id="redeem-code"
            name="code"
            type="text"
            autocomplete="off"
            required
            value={code}
          />
          <button class="button button--action" type="submit">
            {t("redeem.submit")}
          </button>
        </div>
      </form>

      {
        code && (
          <div class="redeem-result" aria-live="polite">
            <p class="result-label">
              {accessText
                ? t("redeem.result.label")
                : t("redeem.error.label")}
            </p>
            <output>
              {accessText ||
                (lookupError
                  ? t("redeem.error.service")
                  : t("redeem.error.unavailable"))}
            </output>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .title-band {
    background: var(--color-action);
    color: var(--color-ink);
    padding-block: var(--space-7);
  }

  .eyebrow {
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: var(--text-2xl);
    text-transform: uppercase;
  }

  .intro {
    max-width: var(--width-reading);
    margin: var(--space-4) 0 0;
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .redeem-section {
    padding-block: var(--space-7) var(--space-8);
  }

  .redeem-form {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-rule);
  }

  label,
  .result-label {
    display: block;
    margin-bottom: var(--space-2);
    font-weight: 600;
  }

  .form-row {
    display: flex;
    gap: var(--space-3);
  }

  input {
    min-width: 0;
    flex: 1;
    padding: var(--space-3);
    border: 1px solid var(--color-muted);
    background: var(--color-paper);
    color: var(--color-ink);
    font: inherit;
  }

  .redeem-result {
    margin-top: var(--space-6);
    padding: var(--space-5);
    border-left: 4px solid var(--color-action);
    background: var(--color-wash);
  }

  .result-label {
    margin-top: 0;
    color: var(--color-muted);
    font-size: var(--text-sm);
    text-transform: uppercase;
  }

  output {
    display: block;
    overflow-wrap: anywhere;
    font-family: ui-monospace, "Cascadia Code", "Roboto Mono", Menlo, Consolas,
      monospace;
    font-size: var(--text-xl);
    font-weight: 700;
    white-space: pre-wrap;
  }

  @media (max-width: 32rem) {
    .form-row {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
