---
import { isLang, useTranslations } from "../../i18n/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { lookupRedeemCode } from "../../redeem/data";
import { redeemRateLimit } from "../../redeem/rate-limit";

export const prerender = false;

const lang = isLang(Astro.params.lang) ? Astro.params.lang : "en";
const t = useTranslations(lang);
Astro.response.headers.set("Cache-Control", "private, no-store, max-age=0");
Astro.response.headers.set("Pragma", "no-cache");
// Avoid sending the page URL while retaining an origin-only referrer.
Astro.response.headers.set("Referrer-Policy", "origin");
Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow, noarchive");

let code = "";
let accessText: string | null = null;
let lookupError = false;
let rateLimited = false;

if (Astro.request.method === "GET") {
  code = Astro.url.searchParams.get("code")?.trim() || "";
} else if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const submittedCode = formData.get("code");
  code = typeof submittedCode === "string" ? submittedCode.trim() : "";
}

if (code) {
  const retryAfter = redeemRateLimit(Astro.request);
  if (retryAfter !== null) {
    Astro.response.status = 429;
    Astro.response.headers.set("Retry-After", String(retryAfter));
    rateLimited = true;
  } else {
    try {
      accessText = await lookupRedeemCode(code);
    } catch (error: unknown) {
      const safeDetails =
        typeof error === "object" && error !== null
          ? {
              name: "name" in error ? String(error.name) : "Error",
              statusCode:
                "statusCode" in error ? String(error.statusCode) : undefined,
              serviceCode: "code" in error ? String(error.code) : undefined,
              requestId:
                "requestId" in error ? String(error.requestId) : undefined,
            }
          : { name: "UnknownError" };
      console.error("Redeem code lookup failed", safeDetails);
      lookupError = true;
    }
  }
}
---

<BaseLayout
  lang={lang}
  title={t("redeem.title")}
  description={t("redeem.intro")}
  robots="noindex, nofollow, noarchive"
>
  <section class="title-band">
    <div class="wrap wrap--reading">
      <p class="eyebrow">{t("redeem.eyebrow")}</p>
      <h1>{t("redeem.title")}</h1>
      <p class="intro">{t("redeem.intro")}</p>
    </div>
  </section>

  <section class="redeem-section">
    <div class="wrap wrap--reading">
      <form
        class="redeem-form"
        method="post"
        action={`${Astro.url.pathname}#redeem-result`}
      >
        <label for="redeem-code">{t("redeem.code.label")}</label>
        <p class="input-hint" id="redeem-code-hint">{t("redeem.code.hint")}</p>
        <div class="form-row">
          <input
            id="redeem-code"
            name="code"
            type="text"
            autocomplete="off"
            autocapitalize="characters"
            aria-describedby="redeem-code-hint"
            maxlength="80"
            required
            spellcheck="false"
            value={code}
          />
          <button class="button button--action" type="submit">
            {t("redeem.submit")}
          </button>
        </div>
      </form>

      {
        code && (
          <div
            class="redeem-result"
            id="redeem-result"
            role={accessText ? "status" : "alert"}
            tabindex="-1"
            aria-labelledby="redeem-result-label"
          >
            <p class="result-label" id="redeem-result-label">
              {accessText
                ? t("redeem.result.label")
                : t("redeem.error.label")}
            </p>
            <output>
              {accessText ||
                (rateLimited
                  ? t("redeem.error.rateLimit")
                  : lookupError
                  ? t("redeem.error.service")
                  : t("redeem.error.unavailable"))}
            </output>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelector<HTMLElement>("#redeem-result")?.focus();
</script>

<style>
  .title-band {
    background: var(--color-action);
    color: var(--color-ink);
    padding-block: var(--space-7);
  }

  .eyebrow {
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: var(--text-2xl);
    text-transform: uppercase;
  }

  .intro {
    max-width: var(--width-reading);
    margin: var(--space-4) 0 0;
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .redeem-section {
    padding-block: var(--space-7) var(--space-8);
  }

  .redeem-form {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-rule);
  }

  label,
  .result-label {
    display: block;
    margin-bottom: var(--space-2);
    font-weight: 600;
  }

  .input-hint {
    margin: calc(-1 * var(--space-1)) 0 var(--space-3);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .form-row {
    display: flex;
    gap: var(--space-3);
  }

  input {
    min-width: 0;
    flex: 1;
    padding: var(--space-3);
    border: 1px solid var(--color-muted);
    background: var(--color-paper);
    color: var(--color-ink);
    font: inherit;
  }

  .redeem-result {
    margin-top: var(--space-6);
    padding: var(--space-5);
    border-left: 4px solid var(--color-action);
    background: var(--color-wash);
  }

  .result-label {
    margin-top: 0;
    color: var(--color-muted);
    font-size: var(--text-sm);
    text-transform: uppercase;
  }

  output {
    display: block;
    overflow-wrap: anywhere;
    font-family: ui-monospace, "Cascadia Code", "Roboto Mono", Menlo, Consolas,
      monospace;
    font-size: var(--text-base);
    font-weight: 700;
    white-space: pre-wrap;
  }

  @media (max-width: 32rem) {
    .form-row {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
