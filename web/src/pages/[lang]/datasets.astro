---
import { getCollection, render } from "astro:content";
import { type Lang, useTranslations } from "../../i18n/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "de" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const entries = (
  await getCollection("datasets", (entry) => entry.id.startsWith(`${lang}/`))
).sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content,
  })),
);

const groups = [
  {
    key: "festival",
    items: rendered.filter(({ entry }) => entry.data.group === "festival"),
  },
  {
    key: "recommended",
    items: rendered.filter(({ entry }) => entry.data.status === "recommended"),
  },
  {
    key: "preparation",
    items: rendered.filter(({ entry }) => entry.data.status === "preparation"),
  },
  {
    key: "optional",
    items: rendered.filter(({ entry }) => entry.data.status === "optional"),
  },
] as const;

const copy = {
  en: {
    intro:
      "The Festival 2026 program export and the strongest Linz sources found in a review of all 820 city catalog records. Readiness labels show what teams can use directly and what still needs organizer preparation.",
    festival: "The festival dataset",
    recommended: "Recommended Linz sources",
    preparation: "Preparation required",
    optional: "Optional and showcase sources",
    status: {
      recommended: "Recommended source",
      preparation: "Organizer preparation required",
      optional: "Optional / showcase",
    },
    source: "Source",
    open: "Open primary source",
  },
  de: {
    intro:
      "Der Programm-Export des Festivals 2026 und die stärksten Linzer Quellen aus der Prüfung aller 820 städtischen Katalogeinträge. Die Kennzeichnung zeigt, was Teams direkt verwenden können und was noch zentral aufbereitet werden muss.",
    festival: "Der Festival-Datensatz",
    recommended: "Empfohlene Linzer Quellen",
    preparation: "Aufbereitung erforderlich",
    optional: "Optionale und Showcase-Quellen",
    status: {
      recommended: "Empfohlene Quelle",
      preparation: "Zentrale Aufbereitung erforderlich",
      optional: "Optional / Showcase",
    },
    source: "Quelle",
    open: "Zur primären Quelle",
  },
}[lang];
---

<BaseLayout lang={lang} title={t("nav.datasets")} description={copy.intro}>
  <section class="title-band">
    <div class="wrap">
      <h1>{t("nav.datasets")}</h1>
      <p class="intro">{copy.intro}</p>
    </div>
  </section>

  {
    groups.map((group) => group.items.length > 0 && (
      <section class="group">
        <div class="wrap">
          <h2>{copy[group.key]}</h2>
          {group.items.map(({ entry, Content }) => (
            <article>
              <header>
                <h3>{entry.data.title}</h3>
                {entry.data.status && (
                  <p class={`status status--${entry.data.status}`}>
                    {copy.status[entry.data.status]}
                  </p>
                )}
                <p class="meta">
                  {copy.source}: {entry.data.provider}
                </p>
              </header>
              <div class="body">
                <p class="summary">{entry.data.summary}</p>
                <div class="prose">
                  <Content />
                </div>
                <p>
                  <a class="button button--outline" href={entry.data.url}>
                    {copy.open}
                  </a>
                </p>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>

<style>
  .title-band {
    background: var(--color-places);
    color: var(--color-paper);
    padding-block: var(--space-7);
    margin-bottom: var(--space-7);
  }

  .title-band :global(:focus-visible) {
    outline-color: var(--color-paper);
  }

  h1 {
    font-size: var(--text-2xl);
    text-transform: uppercase;
    margin: 0;
  }

  .intro {
    margin: var(--space-4) 0 0;
    font-size: var(--text-lg);
    font-weight: 500;
    max-width: var(--width-reading);
  }

  .group {
    margin-bottom: var(--space-7);
  }

  .group h2 {
    font-size: var(--text-xl);
    text-transform: uppercase;
    border-bottom: 3px solid var(--color-places);
    padding-bottom: var(--space-3);
  }

  article {
    display: grid;
    gap: var(--space-2) var(--space-6);
    padding-block: var(--space-5);
    border-bottom: 1px solid var(--color-rule);
  }

  @media (min-width: 48rem) {
    article {
      grid-template-columns: 1fr 2fr;
    }
  }

  article h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .meta {
    color: var(--color-muted);
    font-size: var(--text-sm);
    margin: 0;
  }

  .status {
    display: inline-block;
    margin: 0 0 var(--space-2);
    padding: var(--space-1) var(--space-2);
    border: 1px solid currentColor;
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.3;
  }

  .status--recommended {
    color: #006b55;
  }

  .status--preparation {
    color: #9d1448;
  }

  .status--optional {
    color: #5f356e;
  }

  .summary {
    font-weight: 500;
  }

  .body :global(p:last-of-type) {
    margin-bottom: 0;
  }

  .body > p:last-child {
    margin: var(--space-4) 0 0;
  }
</style>
