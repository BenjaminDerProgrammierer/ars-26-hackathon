---
import { getCollection } from "astro:content";
import { href, type Lang, useTranslations } from "../../i18n/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "de" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const statusOrder = [
  "essential",
  "recommended",
  "optional",
  "in-progress",
] as const;

const datasets = (await getCollection("datasets")).sort((a, b) => {
  const statusDifference =
    statusOrder.indexOf(a.data.status) - statusOrder.indexOf(b.data.status);
  return statusDifference || a.data.title.localeCompare(b.data.title, "de");
});

const copy = {
  en: {
    eyebrow: "Festival & Linz Open Data",
    intro:
      "Start with the Festival 2026 program export, then explore a reviewed catalog of Linz datasets. Each entry records readiness, format, data vintage, practical limitations, and primary sources.",
    sourceLanguage:
      "The authoritative dataset notes are maintained in German. Interface labels remain available in English and German.",
    count: `${datasets.length + 1} datasets`,
    format: "Format",
    vintage: "Data vintage",
    open: "View dataset notes",
    overview: "Read the review method and full verdict",
    festival: {
      eyebrow: "Start here // Official Festival dataset",
      title: "Festival 2026 Program Export",
      summary:
        "The current Negotiating Humanity program export as one JSON file: 706 projects, 360 contacts, 138 locations, and 278 calendar rows.",
      provider: "Ars Electronica",
      format: "JSON, approximately 3 MB",
      vintage: "Exports, updated regularly",
      description:
        "This is a working CMS export with bilingual program descriptions, categories, ticket requirements, contacts, venues, and calendar slots. Normalize linked IDs to their trailing hashes, read event times from the calendar side, filter internal records, and validate coordinates before spatial use.",
      download: "Download the latest export",
      guide: "Read the dataset guide",
    },
    status: {
      essential: {
        heading: "Essential",
        label: "Use",
        description:
          "Strong default sources that need only light normalization.",
      },
      recommended: {
        heading: "Recommended",
        label: "Recommended",
        description:
          "Strong candidates that sit between essential defaults and optional sources.",
      },
      "in-progress": {
        heading: "Decision in progress",
        label: "Pending",
        description:
          "Promising sources with metadata, licensing, or preparation still to resolve.",
      },
      optional: {
        heading: "Optional and experimental",
        label: "Optional",
        description:
          "Secondary sources for clearly scoped prototypes and showcase ideas.",
      },
    },
  },
  de: {
    eyebrow: "Festival- & Linz-Open-Data",
    intro:
      "Beginnt mit dem Programm-Export des Festivals 2026 und erkundet danach den geprüften Katalog Linzer Datensätze. Jeder Eintrag dokumentiert Reifegrad, Format, Datenstand, praktische Einschränkungen und Primärquellen.",
    sourceLanguage:
      "Die verbindlichen Datensatzhinweise werden auf Deutsch gepflegt. Die Navigation ist auf Deutsch und Englisch verfügbar.",
    count: `${datasets.length + 1} Datensätze`,
    format: "Format",
    vintage: "Datenstand",
    open: "Datensatzhinweise öffnen",
    overview: "Prüfmethode und Gesamturteil lesen",
    festival: {
      eyebrow: "Hier beginnen // Offizieller Festival-Datensatz",
      title: "Festival 2026 Programm-Export",
      summary:
        "Der aktuelle Programm-Export von Negotiating Humanity als eine JSON-Datei: 706 Projekte, 360 Kontakte, 138 Orte und 278 Kalenderzeilen.",
      provider: "Ars Electronica",
      format: "JSON, etwa 3 MB",
      vintage: "Exports, regemäßig aktualisiert",
      description:
        "Dies ist ein Arbeits-Export aus dem CMS mit zweisprachigen Programmbeschreibungen, Kategorien, Ticketangaben, Kontakten, Orten und Kalenderterminen. Normalisiert verknüpfte IDs auf den abschließenden Hash, lest Veranstaltungszeiten von der Kalenderseite, filtert interne Einträge und prüft Koordinaten vor räumlichen Anwendungen.",
      download: "Aktuellen Export herunterladen",
      guide: "Datensatz-Anleitung lesen",
    },
    status: {
      essential: {
        heading: "Essenziell",
        label: "Verwenden",
        description:
          "Starke Standardquellen, die nur leicht normalisiert werden müssen.",
      },
      recommended: {
        heading: "Empfohlen",
        label: "Empfohlen",
        description:
          "Starke Kandidaten zwischen essenziellen Standardquellen und optionalen Quellen.",
      },
      "in-progress": {
        heading: "Entscheidung offen",
        label: "In Klärung",
        description:
          "Vielversprechende Quellen mit offenen Metadaten-, Lizenz- oder Aufbereitungsfragen.",
      },
      optional: {
        heading: "Optional und experimentell",
        label: "Optional",
        description:
          "Sekundäre Quellen für klar begrenzte Prototypen und Showcase-Ideen.",
      },
    },
  },
}[lang];

const groups = statusOrder.map((status) => ({
  status,
  items: datasets.filter((dataset) => dataset.data.status === status),
}));

function slugFor(id: string): string {
  return id.split("/")[0];
}
---

<BaseLayout lang={lang} title={t("nav.datasets")} description={copy.intro}>
  <section class="title-band">
    <div class="wrap">
      <p class="eyebrow">{copy.eyebrow} // {copy.count}</p>
      <h1>{t("nav.datasets")}</h1>
      <p class="intro">{copy.intro}</p>
      <p class="language-note">{copy.sourceLanguage}</p>
      <a
        class="overview-link"
        href="https://github.com/BenjaminDerProgrammierer/ars-26-hackathon/blob/main/opendata-linz/README.md"
      >
        {copy.overview} ↗
      </a>
    </div>
  </section>

  <section class="festival-dataset" aria-labelledby="festival-dataset-title">
    <div class="wrap">
      <article class="festival-entry">
        <div class="festival-heading">
          <p class="festival-eyebrow">{copy.festival.eyebrow}</p>
          <h2 id="festival-dataset-title">{copy.festival.title}</h2>
          <p class="provider">{copy.festival.provider}</p>
        </div>
        <div class="festival-body">
          <p class="summary">{copy.festival.summary}</p>
          <p>{copy.festival.description}</p>
          <dl>
            <div>
              <dt>{copy.format}</dt>
              <dd>{copy.festival.format}</dd>
            </div>
            <div>
              <dt>{copy.vintage}</dt>
              <dd>{copy.festival.vintage}</dd>
            </div>
          </dl>
          <div class="festival-actions">
            <a
              class="button"
              href="https://ars.electronica.art/negotiatinghumanity/hackathondata/"
            >
              {copy.festival.download} ↓
            </a>
            <a class="button button--outline" href={href(lang, "tutorials/festival-dataset")}>
              {copy.festival.guide} →
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>

  {
    groups.map(({ status, items }, groupIndex) => (
      <section class="group" aria-labelledby={`group-${status}`}>
        <div class="wrap">
          <header class="group-heading">
            <p class="group-number">{String(groupIndex + 1).padStart(2, "0")}</p>
            <div>
              <h2 id={`group-${status}`}>{copy.status[status].heading}</h2>
              <p>{copy.status[status].description}</p>
            </div>
          </header>

          <ol class="dataset-list">
            {items.map((dataset) => (
              <li>
                <article>
                  <div class="dataset-heading">
                    <p class={`status status--${status}`}>{copy.status[status].label}</p>
                    <h3>
                      <a href={href(lang, `datasets/${slugFor(dataset.id)}`)}>
                        {dataset.data.title}
                      </a>
                    </h3>
                    <p class="provider">{dataset.data.provider}</p>
                  </div>
                  <div class="dataset-body">
                    <p class="summary">{dataset.data.summary}</p>
                    <dl>
                      <div>
                        <dt>{copy.format}</dt>
                        <dd>{dataset.data.format}</dd>
                      </div>
                      <div>
                        <dt>{copy.vintage}</dt>
                        <dd>{dataset.data.data_vintage}</dd>
                      </div>
                    </dl>
                    <a class="detail-link" href={href(lang, `datasets/${slugFor(dataset.id)}`)}>
                      {copy.open} →
                    </a>
                  </div>
                </article>
              </li>
            ))}
          </ol>
        </div>
      </section>
    ))
  }
</BaseLayout>

<style>
  .title-band {
    background: var(--color-places);
    color: var(--color-paper);
    padding-block: var(--space-7);
    margin-bottom: var(--space-7);
  }

  .title-band :global(:focus-visible) {
    outline-color: var(--color-paper);
  }

  .eyebrow {
    margin: 0 0 var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h1 {
    font-size: var(--text-2xl);
    text-transform: uppercase;
    margin: 0;
  }

  .intro {
    margin: var(--space-4) 0 0;
    max-width: var(--width-reading);
    font-size: var(--text-lg);
    font-weight: 500;
  }

  .language-note {
    max-width: var(--width-reading);
    margin: var(--space-4) 0;
    font-size: var(--text-sm);
  }

  .overview-link {
    font-weight: 600;
  }

  .group {
    margin-bottom: var(--space-8);
  }

  .festival-dataset {
    margin-bottom: var(--space-8);
  }

  .festival-entry {
    display: grid;
    gap: var(--space-5) var(--space-6);
    padding-block: var(--space-6);
    border-block: 3px solid var(--color-identity);
  }

  @media (min-width: 48rem) {
    .festival-entry {
      grid-template-columns: minmax(13rem, 1fr) 2fr;
    }
  }

  .festival-eyebrow {
    margin: 0 0 var(--space-3);
    color: #a52c04;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .festival-heading h2 {
    margin-bottom: var(--space-2);
    font-size: var(--text-xl);
    text-transform: uppercase;
  }

  .festival-body > p:not(.summary) {
    max-width: var(--width-reading);
  }

  .festival-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .festival-actions .button:first-child {
    background: var(--color-identity);
    color: var(--color-on-identity);
  }

  .group-heading {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;
    padding-bottom: var(--space-4);
    border-bottom: 3px solid var(--color-places);
  }

  .group-number {
    margin: 0;
    color: var(--color-places);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1;
  }

  .group-heading h2 {
    margin-bottom: var(--space-2);
    font-size: var(--text-xl);
    text-transform: uppercase;
  }

  .group-heading p:last-child {
    max-width: var(--width-reading);
    margin: 0;
  }

  .dataset-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .dataset-list li {
    border-bottom: 1px solid var(--color-rule);
  }

  .dataset-list article {
    display: grid;
    gap: var(--space-4) var(--space-6);
    padding-block: var(--space-5);
  }

  @media (min-width: 48rem) {
    .dataset-list article {
      grid-template-columns: minmax(13rem, 1fr) 2fr;
    }
  }

  h3 {
    margin-bottom: var(--space-2);
    font-size: var(--text-lg);
  }

  .provider {
    color: var(--color-muted);
    font-size: var(--text-sm);
    margin: 0;
  }

  .status {
    display: inline-block;
    margin: 0 0 var(--space-3);
    padding: var(--space-1) var(--space-2);
    border: 1px solid currentColor;
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.3;
  }

  .status--essential {
    color: #006b55;
  }

  .status--recommended {
    color: #9d1448;
  }

  .status--in-progress {
    color: #8a4b00;
  }

  .status--optional {
    color: #5f356e;
  }

  .summary {
    margin-top: 0;
    font-weight: 500;
  }

  dl {
    display: grid;
    gap: var(--space-2) var(--space-5);
    margin: 0 0 var(--space-4);
  }

  @media (min-width: 34rem) {
    dl {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  dt {
    color: var(--color-muted);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  dd {
    margin: 0;
  }

  .detail-link {
    font-weight: 600;
  }
</style>
