---
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="referrer" content="no-referrer" />
    <meta name="robots" content="noindex" />
    <title>Redeem</title>
    <script is:inline define:vars={{ base }}>
      const locale = navigator.languages.find((language) =>
        language.toLowerCase().startsWith("de"),
      );
      const language = locale ? "de" : "en";
      const destination = new URL(
        `${base}${language}/redeem/`,
        window.location.origin,
      );
      destination.search = window.location.search;
      destination.hash = window.location.hash;
      window.location.replace(destination);
    </script>
  </head>
  <body>
    <main>
      <h1>Redeem</h1>
      <p>
        <a href={`${base}en/redeem/`}>Continue in English</a>
        /
        <a href={`${base}de/redeem/`}>Auf Deutsch fortfahren</a>
      </p>
    </main>
  </body>
</html>
