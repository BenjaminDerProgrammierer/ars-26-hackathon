---
import { href } from "../i18n/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout lang="en" title="404">
  <section class="notfound">
    <div class="wrap wrap--reading">
      <h1>404</h1>
      <p>
        This page does not exist — yet. // Diese Seite existiert nicht — noch
        nicht.
      </p>
      <p>
        <a class="button" href={href("en")}>To the hackathon</a>
        <a class="button button--outline" href={href("de")}>Zum Hackathon</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding-block: var(--space-8);
  }

  h1 {
    font-size: var(--text-display);
    color: var(--color-identity);
  }

  p:last-child {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
</style>
