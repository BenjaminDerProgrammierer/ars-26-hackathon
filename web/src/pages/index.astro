---
// Required by Astro's i18n routing: with redirectToDefaultLocale, this route
// backs the / → /en/ redirect. The markup is the static-hosting fallback.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/en/" />
    <link rel="canonical" href="/en/" />
    <title>AI Hackathon — Ars Electronica Festival 2026</title>
  </head>
  <body>
    <p><a href="/en/">AI Hackathon — English</a> // <a href="/de/">Deutsch</a></p>
  </body>
</html>
