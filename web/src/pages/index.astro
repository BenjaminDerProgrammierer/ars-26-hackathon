---
import { href } from "../i18n/ui";

const englishUrl = href("en");
const germanUrl = href("de");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline define:vars={{ englishUrl, germanUrl }}>
      const preferredLanguage = navigator.languages.find((language) =>
        language.toLowerCase().startsWith("de"),
      );
      window.location.replace(preferredLanguage ? germanUrl : englishUrl);
    </script>
    <meta http-equiv="refresh" content={`0; url=${englishUrl}`} />
    <link rel="canonical" href={englishUrl} />
    <title>Redirecting...</title>
  </head>
  <body></body>
</html>
